HOST_DEV=127.0.0.1
PORT_DEV=3000
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:3000
MONGODB_URI_DEV=

CUSTOMER_JWT_SECRET_DEV=
CUSTOMER_REFRESH_JWT_SECRET_DEV=

ADMIN_JWT_SECRET_DEV=
ADMIN_REFRESH_JWT_SECRET_DEV=

# Path to service account JSON (relative to backend/ when you run the server from backend/).
# Copy firebase-service-account.json.example → firebase-service-account.json and paste the real JSON from Firebase, or download from Console (see comment in example file).
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

ADMIN_FULLNAME_DEV=
ADMIN_EMAIL_DEV=
ADMIN_PASSWORD_DEV=

NODE_ENV=development

# GET /api/property?search=… tiered limit window (ms). Per window: guest 10, user 30, admin 100.
PROPERTY_LIST_SEARCH_WINDOW_MS=60000

# GET /api/property without search — max list reads per IP per window (ms).
PROPERTY_LIST_READ_WINDOW_MS=60000
PROPERTY_LIST_READ_MAX=60

# GET /api/property/:id — max detail reads per IP per window (ms).
PROPERTY_BY_ID_READ_WINDOW_MS=60000
PROPERTY_BY_ID_READ_MAX=60