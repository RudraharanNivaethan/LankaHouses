# Copy to `.env` at this folder (project root). Vite merges this with `frontend/.env` (frontend wins on duplicate keys).

# Firebase — Web app (client). Required for email/Google sign-in.
# You can use either VITE_FIREBASE_* OR the shorter names below (same values as Firebase Console → Web app).
# FIREBASE_WEB_API_KEY is mapped to VITE_FIREBASE_API_KEY. If you set FIREBASE_PROJECT_ID, Vite can fill
# authDomain (projectId.firebaseapp.com) and storageBucket (projectId.appspot.com) when those are omitted.
FIREBASE_WEB_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: property search debounce (ms), default 550
VITE_PROPERTY_SEARCH_DEBOUNCE_MS=550
