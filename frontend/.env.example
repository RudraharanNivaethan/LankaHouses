# Vite loads VITE_* from the project root `.env` and this file (this file overrides root on duplicates).
# Root `.env` may use `FIREBASE_WEB_API_KEY` / `FIREBASE_*` aliases — see `vite.config.ts` and `../.env.example`.

# Firebase (Web app config — required for login / Google sign-in)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Debounce (ms) before property list search runs after user stops typing (150–3000, default 550)
VITE_PROPERTY_SEARCH_DEBOUNCE_MS=550
